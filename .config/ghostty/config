# Shared Ghostty configuration.
#
# Ghostty reads this path on both Linux and macOS ($XDG_CONFIG_HOME/ghostty/,
# falling back to ~/.config/ghostty/). On macOS it then layers
# ~/Library/Application Support/com.mitchellh.ghostty/config on top, so keep
# that file absent or it will silently win.
#
# platform.conf is symlinked to linux.conf or macos.conf by the setup script.
# `?` keeps Ghostty quiet if it is missing. It loads first, so anything below
# overrides it.
config-file = ?platform.conf

# Font
font-family = "CaskaydiaMono Nerd Font"
font-style = Regular
theme = Catppuccin Mocha

# Window
window-theme = ghostty
window-padding-x = 14
window-padding-y = 14
confirm-close-surface = false
resize-overlay = never

# Cursor styling
cursor-style = "block"
cursor-style-blink = true

# One key, one value — a second `shell-integration-features` line silently
# replaces the first rather than merging with it.
shell-integration-features = no-cursor,ssh-env

# Keyboard bindings
# TODO: neither keyboard has an Insert key; these two are inert.
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard

# Line + word motion. The cross-platform set — the only arrow chords free on
# both systems (Hyprland owns every super+arrow combo, macOS owns ctrl+arrow
# for Spaces, alt+arrow is split-nav below):
# alt+shift+left/right = jump a word (\x1bb = Alt+B back, \x1bf = Alt+F fwd).
# alt+shift+up/down    = line start/end (\x01 = Ctrl+A, \x05 = Ctrl+E).
# Not ctrl+alt: that lands on the split-nav binds on Linux. On Linux the us/es
# layout toggle lives on both-alts-together (grp:alts_toggle in hypr
# input.conf) so no single-modifier chord can flip it.
keybind = alt+shift+left=text:\x1bb
keybind = alt+shift+right=text:\x1bf
keybind = alt+shift+up=text:\x01
keybind = alt+shift+down=text:\x05

# macOS-native extras: cmd = line, cmd+alt = word. Hyprland eats these on
# Linux, so they are effectively mac-only.
keybind = super+left=text:\x01
keybind = super+right=text:\x05
keybind = super+alt+left=text:\x1bb
keybind = super+alt+right=text:\x1bf
keybind = ctrl+backspace=text:\x17
keybind = ctrl+shift+backspace=text:\x15

# Splits
split-divider-color = #8b2a3f
keybind = ctrl+shift+backslash=new_split:right
keybind = ctrl+shift+e=new_split:down
keybind = ctrl+shift+enter=toggle_split_zoom
keybind = ctrl+shift+equal=equalize_splits
keybind = ctrl+shift+w=close_surface

# Split resizing (20px steps)
keybind = ctrl+shift+h=resize_split:left,20
keybind = ctrl+shift+j=resize_split:down,20
keybind = ctrl+shift+k=resize_split:up,20
keybind = ctrl+shift+l=resize_split:right,20

# Scrolling by keyboard. Not super/cmd: on Omarchy, Super is the Hyprland
# modifier (Super+arrows = movefocus) so it never reaches Ghostty.
keybind = ctrl+shift+up=scroll_page_up
keybind = ctrl+shift+down=scroll_page_down
keybind = ctrl+shift+home=scroll_to_top
keybind = ctrl+shift+end=scroll_to_bottom

# Split navigation
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom
keybind = performable:ctrl+tab=goto_split:next
keybind = performable:ctrl+shift+tab=goto_split:previous

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95
