{
  "permissions": {
    "allow": [
      "Bash(git -C */.dotfiles add *)",
      "Bash(git -C */.dotfiles commit *)",
      "Bash(git -C */.dotfiles push)",
      "Bash(git -C */.dotfiles push *)",
      "Bash(git -C */.dotfiles status)",
      "Bash(git -C */.dotfiles diff *)",
      "Bash(git -C */.dotfiles log *)",
      "Read(~/Documents/Obsidian Vault/**)",
      "Edit(~/Documents/Obsidian Vault/**)",
      "Write(~/Documents/Obsidian Vault/**)",
      "Read(~/Work/**)",
      "Glob(~/Work/**)",
      "Grep(~/Work/**)"
