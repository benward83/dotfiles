    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.kube/**)",
      "Grep(~/.ssh/**)",
      "Grep(~/.kube/**)",
      "Glob(~/.ssh/**)",
      "Glob(~/.kube/**)"
